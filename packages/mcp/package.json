{
  "name": "noder-mcp",
  "version": "1.0.3",
  "description": "MCP-server for norske bedriftsdata fra Brreg",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "noder-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node18 --format=esm --banner:js=\"#!/usr/bin/env node\" --outfile=dist/index.js",
    "dev": "tsc --watch"
  },
  "keywords": [
    "mcp",
    "norway",
    "brreg",
    "norwegian",
    "business-registry",
    "regnskap",
    "claude",
    "cursor"
  ],
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "esbuild": "^0.25.0"
  }
}
